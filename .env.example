# Base URL of the WordPress REST API (no trailing slash, include /wp-json).
WP_API_URL=https://kipl1.gemaromatics.com/wp-json

# Public site URL of this frontend (used for canonical/OG tags & sitemaps).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Edition — selects which design this deployment renders (one codebase, two subdomains):
#   current → experimental build with the Aurum/Verdant theme toggle
#   aurum   → locked dark-amber build that recreates the reference mockups
# Set per deployment. Example:
#   subdomain A (e.g. app.krystal…)   → NEXT_PUBLIC_EDITION=current
#   subdomain B (e.g. krystal…)        → NEXT_PUBLIC_EDITION=aurum
NEXT_PUBLIC_EDITION=current

# Contact / RFQ email delivery (Resend — https://resend.com). Optional in dev:
# if unset, enquiries are logged server-side instead of emailed.
RESEND_API_KEY=
CONTACT_TO_EMAIL=sales@krystalingredients.com
CONTACT_FROM_EMAIL=Krystal Ingredients <noreply@krystalingredients.com>
